{
  "name": "driver-approval-bot",
  "version": "1.0.0",
  "description": "Telegram Driver Approval MVP System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "build:client": "npm --prefix client install --include=dev && npm --prefix client run build",
    "build:all": "npm run build && npm run build:client",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.21.0",
    "sqlite3": "^5.1.6",
    "telegraf": "^4.14.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
